# SiteIQ backend — environment overrides.
# Every Settings field is read from a SITEIQ_* env var (see settings.py).
# Copy this file to `.env` and adjust as needed for local development.

# ---- Environment ----
# dev | prod | test. Affects cookie Secure flag, /dev/outbox visibility, etc.
SITEIQ_ENV=dev

# ---- HTTP / CORS ----
# Comma-separated list of allowed browser origins for CORS + CSRF.
SITEIQ_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# The frontend origin used in email links. Match your Vite dev URL in dev.
SITEIQ_FRONTEND_ORIGIN=http://localhost:5173

# ---- Database ----
# SQLite (zero-setup) for dev/test. Override with postgresql+asyncpg://… in prod.
SITEIQ_DATABASE_URL=sqlite+aiosqlite:///./siteiq.db

# ---- Auth ----
# 32+ random bytes. Used for signing the CSRF double-submit token.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SITEIQ_SESSION_SECRET=please-replace-with-real-random-bytes-in-prod
SITEIQ_SESSION_COOKIE_NAME=siteiq_session
SITEIQ_SESSION_LIFETIME_DAYS=14
SITEIQ_SESSION_IDLE_DAYS=7
# Set to a leaf domain (e.g. .siteiq.app) for cross-subdomain auth in prod.
# Leave unset for localhost / single-host setups so the __Host- prefix can apply.
# SITEIQ_COOKIE_DOMAIN=
# Force the cookie Secure flag on/off. Defaults follow `env` (true in prod).
# SITEIQ_COOKIE_SECURE=

# ---- Email ----
# console: writes to email_outbox + viewable at /dev/outbox (no SMTP setup)
# resend:  posts to api.resend.com via the API key below
SITEIQ_EMAIL_PROVIDER=console
SITEIQ_RESEND_API_KEY=
SITEIQ_EMAIL_FROM="SiteIQ <noreply@siteiq.local>"

# ---- Rate limiting ----
# Empty = in-memory limiter (single-process dev). Use Redis in prod for
# multi-worker correctness, e.g. redis://localhost:6379/0
SITEIQ_RATE_LIMIT_REDIS_URL=

# ---- Simulation ----
SITEIQ_DEFAULT_PROJECT_ID=westhafen

# ---- Logging ----
SITEIQ_LOG_LEVEL=INFO
SITEIQ_LOG_FORMAT=text  # text | json

# ---- Vision ----
SITEIQ_YOLO_MODEL_PATH=yolov8n.pt
SITEIQ_VIDEOS_DIR=vision/videos
