# SiteIQ backend env overrides. Copy this file to `.env` to customise.
# Every variable is OPTIONAL — defaults match the values previously
# hardcoded in main.py.

# Comma-separated list of allowed CORS origins
# SITEIQ_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Default project to load on startup ("westhafen" / "europa-quarter" / "isar-bridge")
# SITEIQ_DEFAULT_PROJECT_ID=westhafen

# Logging
# SITEIQ_LOG_LEVEL=INFO          # DEBUG / INFO / WARNING / ERROR / CRITICAL
# SITEIQ_LOG_FORMAT=text          # text / json

# Vision pipeline
# SITEIQ_YOLO_MODEL_PATH=yolov8n.pt
# SITEIQ_VIDEOS_DIR=vision/videos
